<view class="page">
  <view class="header-card">
    <view class="top-row">
      <view class="city-pill">📍 成都市 ▾</view>
      <view class="top-icons">
        <view class="icon-btn">🔔</view>
        <image class="avatar" src="https://dummyimage.com/72x72/e8e8f9/666&text=U" mode="aspectFill"/>
      </view>
    </view>

    <view class="hero-row">
      <view class="hero-text">
        <text class="title">成都升学助手 <text class="accent">AI</text></text>
        <text class="subtitle">专注成都升学政策解读与升学规划</text>
      </view>
      <image class="robot" src="https://dummyimage.com/260x260/dedcff/5f54ff&text=AI" mode="aspectFit"/>
    </view>

    <view class="ask-box">
      <view class="ask-main">有问题，问AI吧...</view>
      <view class="tag-list">
        <text class="tag">小升初政策</text>
        <text class="tag">学区划分</text>
        <text class="tag">中考填报</text>
        <text class="tag">学校对比</text>
      </view>
      <view class="mic-btn">🎤</view>
    </view>
  </view>

  <view class="card">
    <view class="section-title-row">
      <text class="section-title">热门问题</text>
      <text class="section-extra">换一换 ⟳</text>
    </view>
    <view class="qa-grid">
      <view class="qa-item" wx:for="{{hotQuestions}}" wx:key="index">
        <text class="search-icon">⌕</text>
        <text class="qa-text">{{item}}</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <view class="feature-grid">
    <view class="feature-item" wx:for="{{features}}" wx:key="title">
      <view class="feature-icon">{{item.icon}}</view>
      <text class="feature-title">{{item.title}}</text>
      <text class="feature-sub">{{item.sub}}</text>
    </view>
  </view>

  <view class="banner">
    <view>
      <text class="banner-title">生成升学指导报告</text>
      <text class="banner-sub">AI为你定制专属升学方案</text>
      <view class="banner-btn">立即生成 ›</view>
    </view>
  </view>

  <view class="card trust-row">
    <view class="trust-item" wx:for="{{trustItems}}" wx:key="title">
      <text class="trust-icon">{{item.icon}}</text>
      <view>
        <text class="trust-title">{{item.title}}</text>
        <text class="trust-sub">{{item.sub}}</text>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title-row">
      <text class="section-title">最近生成的报告</text>
      <text class="section-extra">查看全部 ›</text>
    </view>
    <view class="report-item">
      <view class="doc-thumb">📄</view>
      <view class="report-main">
        <text class="report-title">高新区小升初升学方案</text>
        <view class="chips">
          <text class="chip">小升初</text>
          <text class="chip">高新区</text>
        </view>
        <text class="report-time">生成时间：2024-05-19 14:30</text>
      </view>
      <view class="report-btn">查看报告</view>
    </view>
  </view>

  <view class="tabbar-placeholder"></view>
  <view class="tabbar">
    <view class="tab active">首页</view>
    <view class="tab">问答记录</view>
    <view class="tab center">AI问答</view>
    <view class="tab">报告</view>
    <view class="tab">我的</view>
  </view>
</view>
